// This is your Prisma schema file for IProCore Phase 01 + Phase 02 (Gap Remediation)
// Cloud SQL (PostgreSQL) compatible — explicit migrations only

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANCY ─────────────────────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  plan        String   @default("starter") // starter | pro | enterprise
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  memberships      Membership[]
  roles            Role[]
  auditLogs        AuditLog[]
  portfolioItems   PortfolioItem[]
  onboardingSteps  OnboardingStep[]
  helpTickets      HelpTicket[]
  aiSuggestions    AiSuggestion[]   // Phase 05
  aiActivityLogs   AiActivityLog[]  // Phase 05
}

// ─── IDENTITY ────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  locale       String   @default("en") // en | ar
  dir          String   @default("ltr") // ltr | rtl
  twoFaEnabled Boolean   @default(false)
  lastLoginAt  DateTime?               // Set on each successful login — security badge
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  memberships   Membership[]
  auditLogs     AuditLog[]   @relation("ActorAuditLogs")
  refreshTokens RefreshToken[]
  helpTickets   HelpTicket[] @relation("UserHelpTickets")
  aiSuggestions   AiSuggestion[]  @relation("RequesterSuggestions")  // Phase 05
  aiActivityLogs  AiActivityLog[] @relation("ActorAiActivityLogs")  // Phase 05

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model Membership {
  id         String   @id @default(uuid())
  userId     String
  tenantId   String
  memberRole String   @default("member") // owner | admin | developer | member
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean  @default(false) // system roles cannot be deleted
  createdAt   DateTime @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String @id @default(uuid())
  key         String @unique // e.g. "portfolio:manage", "users:read"
  description String

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique // bcrypt hash of the raw refresh token
  family     String    // same family = rotate together, reuse = revoke all
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([family])
}

// ─── AUDIT LOG (APPEND-ONLY) ──────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  actorId    String   // userId
  action     String   // e.g. "portfolio.create", "auth.login", "user.role_change"
  resource   String   // e.g. "PortfolioItem"
  resourceId String?
  meta       Json?    // additional context — NO SECRETS
  requestId  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User   @relation("ActorAuditLogs", fields: [actorId], references: [id])

  // No update/delete operations allowed — append-only enforced at service layer
  @@index([tenantId])
  @@index([actorId])
}

// ─── PORTFOLIO REGISTRY ───────────────────────────────────────────────────────

model PortfolioItem {
  id                  String   @id @default(uuid())
  tenantId            String   // null = global (system items visible to all tenants)
  name                String
  type                String   // product | engine | platform
  icon                String?
  descriptionEn       String
  descriptionAr       String
  launchUrlProd       String?
  launchUrlStage      String?
  ssoMode             String   @default("handoff") // handoff | oidc
  requiredPermissions String[] @default([])
  requiredConnectors  String[] @default([])
  suggestedPlaybooks  String[] @default([])
  defaultPlansVisibility String[] @default([]) // plan slugs
  version             String   @default("1.0.0")
  status              String   @default("draft") // draft | published | disabled
  rolloutMode         String   @default("all") // all | allowlistTenants | allowlistPlans
  allowlistTenants    String[] @default([])
  allowlistPlans      String[] @default([])
  killSwitch          Boolean  @default(false)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

// ─── ONBOARDING ───────────────────────────────────────────────────────────────

model OnboardingStep {
  id          String    @id @default(uuid())
  tenantId    String
  key         String    // unique step identifier e.g. "setup_profile"
  titleEn     String
  titleAr     String
  descEn      String?
  descAr      String?
  order       Int       @default(0)
  isRequired  Boolean   @default(true)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@index([tenantId])
}

// ─── HELP & SUPPORT ───────────────────────────────────────────────────────────

model HelpTicket {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  subject   String
  body      String
  status    String   @default("open") // open | in_progress | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation("UserHelpTickets", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
}

// ─── KNOWLEDGE BASE ───────────────────────────────────────────────────────────

model KBArticle {
  id        String   @id @default(uuid())
  tenantId  String?  // null = global article visible to all tenants
  titleEn   String
  titleAr   String
  bodyEn    String
  bodyAr    String
  category  String   @default("general")
  published Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
}


// ─── AI ASSIST LAYER (PHASE 05) ───────────────────────────────────────────────
//
// Rules (Blueprint §9 + Founder governance order):
// - AI is assistive only: draft/suggest/summarize
// - No secret values ever stored in contextSummary or suggestionText
// - Execution requires server-side confirmation gate (AiConfirmation record)
// - triggerSource = 'AI' on all WorkflowRuns dispatched here
// - AiActivityLog is append-only — no update/delete allowed

/// AI-generated suggestion draft.
/// contextSummary and suggestionText contain sanitised text — credentials NEVER stored.
model AiSuggestion {
  id                   String    @id @default(uuid())
  tenantId             String
  requestingUserId     String
  suggestionType       String    // workflow_draft | onboarding_draft | help_reply | integration_suggestion
  contextSummary       String    // what context was given to AI — secrets redacted before storage
  suggestionText       String    // the draft output — assistive only
  status               String    @default("pending") // pending | confirmed | dismissed | expired
  confirmedAt          DateTime?
  confirmedByUserId    String?   // null until confirmed
  workflowRunId        String?   // JAD WorkflowRun ID if executed (triggerSource='AI')
  requestId            String?   // propagated X-Request-ID
  expiresAt            DateTime  // 48h TTL — auto-expiry enforced at service layer
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant        Tenant  @relation(fields: [tenantId], references: [id])
  requester     User    @relation("RequesterSuggestions", fields: [requestingUserId], references: [id])
  confirmations AiConfirmation[]

  @@index([tenantId])
  @@index([status])
  @@index([requestingUserId])
}

/// Append-only server-side confirmation gate record.
/// Created when a user confirms or dismisses an AiSuggestion via the server API.
/// UI modal alone is insufficient — this record is the authoritative gate.
model AiConfirmation {
  id                String   @id @default(uuid())
  tenantId          String
  suggestionId      String
  requestingUserId  String   // must match AiSuggestion.requestingUserId
  approvedByUserId  String   // the confirming user (same as requesting in Phase 05)
  confirmationAction String  // confirm | dismiss
  requestId         String?
  createdAt         DateTime @default(now())

  suggestion AiSuggestion @relation(fields: [suggestionId], references: [id])

  @@index([tenantId])
  @@index([suggestionId])
}

/// Immutable AI audit trail — append-only.
/// Records all AI interactions: suggestion created, confirmed, dispatched to JAD.
/// triggerSource is always 'AI'. No update/delete allowed at service layer.
model AiActivityLog {
  id              String   @id @default(uuid())
  tenantId        String
  actorId         String   // userId
  action          String   // ai.suggestion.created | ai.confirmation.approved | ai.execution.dispatched | ai.help.suggested
  suggestionId    String?  // nullable — not all AI actions have a suggestion
  workflowRunId   String?  // JAD WorkflowRun ID when execution dispatched
  triggerSource   String   @default("AI") // ALWAYS 'AI' for this model
  requestId       String?
  meta            Json?    // summary only — NO secrets, NO OAuth tokens, NO credentialRef
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User   @relation("ActorAiActivityLogs", fields: [actorId], references: [id])

  @@index([tenantId])
  @@index([actorId])
  @@index([action])
}
