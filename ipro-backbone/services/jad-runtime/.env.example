# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Separate JAD Postgres database — NOT the same as IProCore
JAD_DATABASE_URL="postgresql://postgres:password@localhost:5432/jad"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Must match IProCore ACCESS_TOKEN_SECRET — JAD validates the same access token
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JAD_IPROCORE_ACCESS_SECRET="SAME_AS_IPROCORE_ACCESS_TOKEN_SECRET"

# ─── IPROCORE INTEGRATION ─────────────────────────────────────────────────────
# URL for fire-and-forget audit events back to IProCore
IPROCORE_AUDIT_URL="http://localhost:3000/api/audit"

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
